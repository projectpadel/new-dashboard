# Salin ke .env atau .env.local di folder ini.
# Dev lokal: npm.cmd run dev → http://localhost:5174 (PORT=5174 default di vite.config / scripts/dev.mjs)
# URL dan anon key: Project Settings → API di dashboard Supabase.

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-public-key

# Wajib untuk dashboard admin (server function / supabaseAdmin).
# Project Settings → API → service_role (secret). Jangan expose ke frontend / jangan commit .env.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# AI Assistant (Edge Function ai-assistant) — set di Supabase Dashboard → Edge Functions → Secrets
#   OPENAI_API_KEY, OPENAI_MODEL (opsional, default gpt-4o-mini)
# Lokal Netlify/TanStack tidak lagi memanggil OpenAI untuk chat admin.
# OPENAI_API_KEY=sk-your-openai-key
# OPENAI_MODEL=gpt-4o-mini

# Opsional: UUID superadmin untuk verifikasi RPC is_superadmin pada mutasi role/instruktur
# SUPERADMIN_ACTOR_USER_ID=00000000-0000-4000-8000-000000000001
