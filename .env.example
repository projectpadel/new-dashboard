# Salin ke .env atau .env.local di folder ini.
# URL dan anon key: Project Settings → API di dashboard Supabase.

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-public-key

# Wajib untuk dashboard admin (server function / supabaseAdmin).
# Project Settings → API → service_role (secret). Jangan expose ke frontend / jangan commit .env.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Server-only — jangan pakai prefix VITE_. Alternatif: baris di tabel platform_secrets (key: openai_api_key).
OPENAI_API_KEY=sk-your-openai-key
OPENAI_MODEL=gpt-4o-mini

# Opsional: UUID superadmin untuk verifikasi RPC is_superadmin pada mutasi role/instruktur
# SUPERADMIN_ACTOR_USER_ID=00000000-0000-4000-8000-000000000001
